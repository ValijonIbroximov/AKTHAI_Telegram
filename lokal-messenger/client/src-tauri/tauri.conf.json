{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Harbiy Messenjer",
  "version":     "0.1.0",
  "identifier":  "uz.mil.lokal-messenger",

  "app": {
    "windows": [
      {
        "title":           "Harbiy Messenjer",
        "width":           960,
        "height":          640,
        "minWidth":        720,
        "minHeight":       480,
        "resizable":       true,
        "decorations":     false,
        "transparent":     false,
        "center":          true,
        "url":             "index.html"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://server.lokal:8443 wss://server.lokal:8443; script-src 'self'"
    }
  },

  "build": {
    "beforeDevCommand":   "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl":             "http://localhost:1420",
    "frontendDist":       "../dist"
  },

  "bundle": {
    "active":  true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  },

  "plugins": {
    "log": {
      "level": "warn",
      "targets": [
        { "kind": "stdout" },
        { "kind": "folder", "path": "./logs" }
      ]
    }
  }
}
